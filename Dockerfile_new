FROM nvidia/cuda:12.9.1-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-venv \
    git \
    && rm -rf /var/lib/apt/lists/*

# Venv im System-Pfad erstellen
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

ARG VLLM_NIGHTLY="false"
COPY builder/requirements.txt /requirements.txt

# Installation
RUN if [ "${VLLM_NIGHTLY}" = "true" ]; then \
        uv pip install --no-cache-dir -U vllm --pre --extra-index-url https://wheels.vllm.ai/nightly/ && \
        uv pip install --no-cache-dir git+https://github.com/huggingface/transformers.git; \
    else \
        uv pip install --no-cache-dir -U "vllm[flashinfer]" --extra-index-url https://download.pytorch.org/whl/cu124; \
    fi && \
    uv pip install --no-cache-dir -r /requirements.txt

# CUDA Kompatibilität sicherstellen
RUN ldconfig /usr/local/cuda-12.9/compat/

# User Setup
RUN useradd -m -u 1000 vllmuser
WORKDIR /app
COPY src/ /app/src/
RUN chown -R vllmuser:vllmuser /app

USER vllmuser

ENV PYTHONPATH="/app" \
    RAYON_NUM_THREADS=4 \
    TOKENIZERS_PARALLELISM=false \
    LD_LIBRARY_PATH="/usr/local/cuda/lib64:/usr/local/cuda/compat:$LD_LIBRARY_PATH"

ARG MODEL_NAME=""
RUN if [ -n "$MODEL_NAME" ]; then \
        python3 /app/src/download_model.py; \
    fi

CMD ["python3", "/app/src/handler.py"]
